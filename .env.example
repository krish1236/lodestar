# Copy to .env for local runs (never commit .env — it is gitignored).
# In GitHub Actions these are provided as encrypted repository secrets.

# Required for the "why this matters" one-liner. If unset, the digest still
# builds — it just omits the one-liners (useful for offline / no-key testing).
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults are set in config.py).
# LODESTAR_HAIKU_MODEL=claude-haiku-4-5-20251001
