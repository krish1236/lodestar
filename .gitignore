# --- Internal design docs (kept local, not published) ---
docs/

# --- Secrets / env ---
.env
.env.*
!.env.example
secrets.*

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
